	<appSettings>
		<!--数据库连接字符串-->
		<add key="ConString" value="server=127.0.0.1; database=Inkjet_Print_Db;uid=root;pwd=pr123456;charset=utf8;port=3306" />
    <add key="ConStringRemote" value="server=127.0.0.1; database=Inkjet_Print_Db;uid=root;pwd=pr123456;charset=utf8;port=3306" />
         
		<add key="Md5_Salt" value="szprkj" />    
		<!--PLC 192.168.3.21-->
        <add key="PLCIP" value="192.168.3.21" />
		<add key="PLCPort" value="5010" />
		
		<!--激光清洗工序PLC-->
		<add key="PLC_Clear_IP" value="192.168.3.51" />
		<add key="PLC_Clear_Port" value="4095" />
		
		<add key="GunIP" value="192.168.1.201" />
		<add key="GunPort" value="502" />
		<add key="MonitorIP" value="opc.tcp://HW-1014:49580" />
		<add key="LogPath" value="D:\SpcLogs\Logs" />
    <add key="LogErrPath" value="D:\SpcLogs\Errors" />
    <!--是否采集数据-->
    <add key="PlcEnable" value="1" />
		
		<!--摆放超时时间(单位：小时)-->
		<add key="PlacementTimeout" value="6" />
	</appSettings>
	<startup>
